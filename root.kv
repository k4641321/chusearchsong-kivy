#:kivy 2.3.1

# from loguru import logger
#:import Factory kivy.factory.Factory
#:import logger loguru.logger
<ChineseSpinnerOption@SpinnerOption>:
    font_name: 'simhei.ttf'
    height: dp(30)
    text_size: self.width, None
    valign: 'middle'
    halign: 'center'

# 根容器
BoxLayout:
    id: rootbox
    orientation: 'vertical'
    pos_hint: {"left":1,"top":1,}
    #搜索容器
    BoxLayout:
        id: searchbox
        orientation: 'horizontal'
        pos_hint: {"left":1,"top":1,}
        size_hint_y: None
        height: dp(30)
        #搜索框
        TextInput:
            id: searchinput
            hint_text: "Search..."
            size_hint_y: None
            size_hint_x: 0.8
            height: dp(30)
            pos_hint: {"left":1,"top":1,}
            font_name: 'simhei.ttf'
        Button:
            text: "搜索"
            size_hint_y: None
            size_hint_x: 0.2
            height: dp(30)
            pos_hint: {"right":1,"top":1,}
            font_name: 'simhei.ttf'
            on_press: app.schedule_search_with_clock()
    BoxLayout:
        orientation: 'horizontal'
        id:filterBox
        size_hint_y: None
        height: dp(30)
        Spinner:
            id: genreSpinner
            size_hint_y: None
            size_hint_x: 0.2
            # pos_hint: {"left":1,"top":0.95,}
            values: ['全部流派','流行 & 动漫', 'niconico', '东方Project', '原创','其他游戏','彩绿','音击舞萌']
            text: '流派'
            option_cls: Factory.ChineseSpinnerOption
            on_text:logger.info(self.text)
            height: dp(30)
            font_name: './simhei.ttf'
        Spinner:
            id:versionSpinner
            size_hint_y: None
            size_hint_x: 0.2
            # pos_hint: {"left":0.8,"top":0.95,}
            values: ['全部版本','CHUNITHM', 'CHUNITHM PLUS', "CHUNITHM AIR", "CHUNITHM AIR PLUS","CHUNITHM STAR","CHUNITHM STAR PLUS","CHUNITHM AMAZON","CHUNITHM AMAZON PLUS","CHUNITHM CRYSTAL","CHUNITHM CRYSTAL PLUS","CHUNITHM PARADISE","CHUNITHM PARADISE LOST","CHUNITHM NEW","CHUNITHM NEW PLUS","CHUNITHM SUN","CHUNITHM SUN PLUS","CHUNITHM LUMINOUS","CHUNITHM LUMINOUS PLUS","CHUNITHM VERSE"]
            text: '版本'
            option_cls: Factory.ChineseSpinnerOption
            on_text:logger.info(self.text)
            height: dp(30)
            font_name: './simhei.ttf'
        Spinner:
            id:diffminSpinner
            size_hint_y: None
            size_hint_x: 0.2
            # pos_hint: {"left":0.6,"top":0.95,}
            values: ['0', '1', '2', '3','4','5','6','7','7.5','8','8.5','9','9.5','10','10.5','11','11.5','12','12.5','13','13.5','14','14.5','15','15.5']
            text: '难度下限'
            option_cls: Factory.ChineseSpinnerOption
            on_text:logger.info(self.text)
            height: dp(30)
            font_name: './simhei.ttf'
        Spinner:
            id:diffmaxSpinner
            size_hint_y: None
            size_hint_x: 0.2
            # pos_hint: {"left":0.4,"top":0.95,}
            values: ['0', '1', '2', '3','4','5','6','7','7.9','8','8.9','9','9.9','10','10.9','11','11.9','12','12.9','13','13.9','14','14.9','15','15.9']
            text: '难度上限'
            option_cls: Factory.ChineseSpinnerOption
            on_text:logger.info(self.text)
            height: dp(30)
            font_name: './simhei.ttf'
        Spinner:
            id:showfavoriteSpinner
            size_hint_y: None
            size_hint_x: 0.2
            # pos_hint: {"left":0.2,"top":0.95,}
            values: ['不展示收藏','展示收藏']
            text: '是否展示收藏'
            option_cls: Factory.ChineseSpinnerOption
            on_text:logger.info(self.text)
            height: dp(30)
            font_name: './simhei.ttf'
    BoxLayout:
        orientation: 'vertical'
        id: resultbox
